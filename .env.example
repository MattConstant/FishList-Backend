# Copy this file to .env (do NOT commit .env) and fill in real values.

# --- Deployed backend (e.g. Render) ---
# Disable Swagger, H2 console, and SQL logging in production:
#   SPRING_PROFILES_ACTIVE=prod
# With Supabase Postgres, use:
#   SPRING_PROFILES_ACTIVE=prod,supabase
#
# Health check (fast, no DB): set in Render → Settings → Health Check Path to /api/health
# Java on 512 MB / 0.1 CPU is very slow to start; prefer at least 1 GB RAM if deploys keep timing out.
# Optional: override JVM flags from Dockerfile defaults (Metaspace is separate from heap — Spring/Hibernate need enough):
#   JAVA_OPTS=-XX:MaxRAMPercentage=55.0 -XX:MaxMetaspaceSize=384m -XX:+UseSerialGC -XX:TieredStopAtLevel=1
#
# CORS defaults are in application.properties. Optional overrides:
#   APP_CORS_ALLOWED_ORIGIN_PATTERNS_0=https://fish-list-frontend.vercel.app
#   APP_CORS_ALLOWED_ORIGIN_PATTERNS_1=https://*.vercel.app

# --- Optional: Supabase PostgreSQL (Spring profile "supabase") ---
# Default local runs use in-memory H2. To use Supabase instead, set:
#   SPRING_PROFILES_ACTIVE=supabase
# or with Docker Compose + MinIO:
#   SPRING_PROFILES_ACTIVE=docker,supabase
# Get host, user, and password from Supabase: Project Settings → Database.
# Direct db.*.supabase.co is often IPv6-only (Docker may fail). Use Session pooler from
# Dashboard → Connect → Shared pooler / Session pooler (host like aws-0-REGION or aws-1-REGION — copy exactly).
# User is usually postgres.YOUR_PROJECT_REF (not plain postgres).
#SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
#SPRING_DATASOURCE_USERNAME=postgres.YOUR_PROJECT_REF
#SPRING_DATASOURCE_PASSWORD=your_database_password_here
#
# If you hit "MaxClientsInSessionMode: max clients reached", lower the pool (default is 4 in application-supabase.properties):
#HIKARI_MAXIMUM_POOL_SIZE=2
#HIKARI_MINIMUM_IDLE=0

# Enable AI fish identification endpoint
OPENAI_ENABLED=true

# Your OpenAI API key (server-side only; never expose in frontend)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: override model
OPENAI_MODEL=gpt-4.1-mini

# Per-user daily cap for AI fish identification requests
OPENAI_IDENTIFY_DAILY_LIMIT=2

# Per-user daily cap for image uploads
IMAGE_UPLOAD_DAILY_LIMIT=15

# Admin username for /api/admin endpoints
ADMIN_USERNAME=your_admin_username_here

# General per-user (or per-IP for anonymous requests) API throttles, per minute
RATE_LIMIT_FEED_PER_MINUTE=60
RATE_LIMIT_SEARCH_PER_MINUTE=40
RATE_LIMIT_STORAGE_DOWNLOAD_URL_PER_MINUTE=60
RATE_LIMIT_LOCATION_WRITES_PER_MINUTE=45
RATE_LIMIT_INTERACTIONS_PER_MINUTE=120

# --- Optional: Supabase Storage (S3-compatible) instead of local MinIO ---
# Dashboard → Project Settings → Storage → S3 connection: generate access key + secret.
# Endpoint must include the path (force path-style in S3 clients):
#   https://YOUR_PROJECT_REF.storage.supabase.co/storage/v1/s3
# Create a bucket (e.g. fishlist) in Storage → Buckets before uploading.
#MINIO_ENDPOINT=https://YOUR_PROJECT_REF.storage.supabase.co/storage/v1/s3
#MINIO_PUBLIC_BASE_URL=https://YOUR_PROJECT_REF.storage.supabase.co/storage/v1/s3
#MINIO_ACCESS_KEY=your_s3_access_key_id
#MINIO_SECRET_KEY=your_s3_secret_access_key
#MINIO_BUCKET=fishlist
#MINIO_REGION=us-east-1
#MINIO_PATH_STYLE=true
